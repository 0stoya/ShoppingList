<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
 <update handle="customer_account" />
    <body>
        <referenceContainer name="content">
            <block class="Ostoya\ShoppingList\Block\Lists" name="tr.shoppinglist.lists" template="Ostoya_ShoppingList::lists.phtml" cacheable="false">
                <arguments>
                    <argument name="viewModel" xsi:type="object">Ostoya\ShoppingList\ViewModel\ListProvider</argument>
                    <argument name="label" xsi:type="string" translate="true">My Shopping Lists</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>


